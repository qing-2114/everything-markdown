{
  "name": "everything-markdown",
  "version": "0.1.1",
  "description": "Windows desktop MVP for converting local files to Markdown with MarkItDown.",
  "main": "src/main.js",
  "scripts": {
    "build:converter": "pyinstaller --clean --onefile --name convert --collect-data magika scripts/convert.py --distpath build/converter --workpath build/pyinstaller --specpath build/pyinstaller",
    "dist:win": "npm run build:converter && electron-builder --win",
    "start": "electron .",
    "test": "node --test tests/*.test.js"
  },
  "keywords": [
    "markdown",
    "electron",
    "markitdown"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.everythingmarkdown.app",
    "productName": "Everything Markdown",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/converter/convert.exe",
        "to": "converter/convert.exe"
      }
    ],
    "win": {
      "artifactName": "Everything Markdown Setup ${version}.${ext}",
      "icon": "src/assets/app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer/nsis/installer.nsh"
    }
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.0.12"
  }
}
